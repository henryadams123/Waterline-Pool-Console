              <label class="lab">Chart metric</label>
              <select id="hist_metric">
                <option value="fc">Free Chlorine</option>
                <option value="pH">pH</option>
                <option value="orp">ORP</option>
                <option value="ta">Alkalinity</option>
                <option value="ch">Calcium Hardness</option>
                <option value="cya">Cyanuric Acid</option>
              </select>
            </div>
            <div id="hist_chart_wrap" style="margin-top:14px"></div>

            <div class="divider"></div>
            <div class="mini-lab"><span class="dot"></span>Trend notes</div>
            <div id="hist_insights" class="analytics" style="padding:0"></div>

            <div class="divider"></div>
            <div class="mini-lab"><span class="dot"></span>Log (<span id="hist_count">0</span> entries)</div>
            <div class="hist-table-wrap"><table class="hist-table" id="hist_table"></table></div>
