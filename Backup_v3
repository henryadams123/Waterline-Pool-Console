<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="theme-color" content="#F3EDE3">
<title>Waterline: Pool Water Console</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600;700&family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#F3EDE3; --bg-2:#EDE4D3; --surface:#FFFFFF; --surface-2:#F1E9DA;
  --line:#DDD0BC; --line-soft:#E9E0D0;
  --accent:#C14E0B; --accent-dim:#9C3D09;
  --good:#4F7A5B; --good-dim:#3D6249;
  --low:#5B7A99; --high:#B23A2E; --warn:#B8860B;
  --ink:#2B211A; --ink-2:#6B5D4F; --ink-3:#9C8D7B;
  --radius:14px;
  --mono:"IBM Plex Mono",ui-monospace,SFMono-Regular,Menlo,monospace;
  --sans:"Lora",Georgia,"Times New Roman",serif;
}
*{box-sizing:border-box}
html{-webkit-text-size-adjust:100%}
body{
  margin:0;background:
    radial-gradient(1000px 560px at 12% -10%, #FBF4E7 0%, transparent 55%),
    radial-gradient(900px 520px at 100% 6%, #F8EFDE 0%, transparent 52%),
    linear-gradient(180deg,var(--bg) 0%, var(--bg-2) 100%);
  color:var(--ink);font-family:var(--sans);font-size:15px;line-height:1.5;min-height:100vh;
}
h1,h2,h3{margin:0;font-weight:600;letter-spacing:-.01em}
a{color:var(--accent)}
.wrap{max-width:1280px;margin:0 auto;padding:26px 22px 80px}

header{position:relative;overflow:hidden;border:1px solid var(--line);border-bottom:3px solid var(--accent);border-radius:var(--radius);padding:26px 28px 24px;margin-bottom:22px;background:var(--surface)}
.brandline{display:flex;align-items:baseline;gap:14px;flex-wrap:wrap;position:relative}
.wordmark{font-family:var(--sans);font-weight:700;font-size:32px;letter-spacing:-.01em;color:var(--ink)}
.wordmark b{color:var(--accent);font-weight:700}
.tag{font-family:var(--mono);font-size:11.5px;letter-spacing:.22em;text-transform:uppercase;color:var(--ink-3)}
.subhead{position:relative;margin-top:8px;color:var(--ink-2);max-width:62ch;font-size:15px;font-style:italic}

.grid{display:grid;grid-template-columns:388px 1fr;gap:22px;align-items:start}
@media (max-width:940px){.grid{grid-template-columns:1fr}}
.panel{background:var(--surface);border:1px solid var(--line-soft);border-radius:var(--radius)}
.inputs{position:sticky;top:16px}
@media (max-width:940px){.inputs{position:static}}
.panel-head{display:flex;align-items:center;gap:10px;padding:15px 18px;border-bottom:1px solid var(--line-soft)}
.panel-head .idx{font-family:var(--mono);font-size:11px;color:var(--accent-dim);letter-spacing:.15em}
.panel-head h2{font-family:var(--mono);font-size:14px;letter-spacing:.1em;text-transform:uppercase;font-weight:600;color:var(--ink)}
.panel-head .note{margin-left:auto;font-family:var(--mono);font-size:10.5px;color:var(--ink-3);letter-spacing:.06em}
.panel-body{padding:16px 18px}

.field{margin-bottom:14px}
.field:last-child{margin-bottom:0}
label.lab{display:block;font-family:var(--mono);font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--ink-2);margin-bottom:6px}
.hint{font-size:11.5px;color:var(--ink-3);margin-top:4px;font-family:var(--mono)}
input[type=number],input[type=date],select{width:100%;background:var(--bg-2);border:1px solid var(--line);border-radius:9px;color:var(--ink);font-family:var(--mono);font-size:15px;padding:9px 11px;outline:none;transition:border-color .15s, box-shadow .15s}
input[type=number]:focus,input[type=date]:focus,select:focus{border-color:var(--accent-dim);box-shadow:0 0 0 3px rgba(193,78,11,.13)}
input[type=number]::-webkit-outer-spin-button,input[type=number]::-webkit-inner-spin-button{opacity:.4}
input[type=date]::-webkit-calendar-picker-indicator{cursor:pointer}
select{appearance:none;background-image:linear-gradient(45deg,transparent 50%,var(--ink-3) 50%),linear-gradient(135deg,var(--ink-3) 50%,transparent 50%);background-position:calc(100% - 16px) 17px,calc(100% - 11px) 17px;background-size:5px 5px,5px 5px;background-repeat:no-repeat}
.row2{display:grid;grid-template-columns:1fr 1fr;gap:10px}

.seg{display:flex;background:var(--bg-2);border:1px solid var(--line);border-radius:9px;padding:3px;gap:3px}
.seg button{flex:1;background:transparent;border:0;color:var(--ink-2);font-family:var(--mono);font-size:12px;padding:7px 4px;border-radius:6px;cursor:pointer;letter-spacing:.03em;transition:.15s}
.seg button.on{background:var(--surface-2);color:var(--accent);box-shadow:inset 0 0 0 1px var(--line)}
.seg button:hover:not(.on){color:var(--ink)}

.divider{height:1px;background:var(--line-soft);margin:16px 0}
.mini-lab{font-family:var(--mono);font-size:10.5px;letter-spacing:.2em;text-transform:uppercase;color:var(--ink-3);margin:2px 0 10px;display:flex;align-items:center;gap:8px}
.mini-lab .dot{width:6px;height:6px;border-radius:50%;background:var(--accent-dim)}
.volout{font-family:var(--mono);background:var(--bg-2);border:1px dashed var(--line);border-radius:9px;padding:10px 12px;display:flex;justify-content:space-between;align-items:baseline;margin-top:4px}
.volout small{color:var(--ink-3);font-size:11px;letter-spacing:.1em;text-transform:uppercase}
.volout b{color:var(--accent);font-size:18px;font-weight:600}

/* water sync slider */
.verdict{padding:18px;border-bottom:1px solid var(--line-soft)}
.swim-head{display:flex;justify-content:space-between;align-items:baseline;gap:12px;margin-bottom:11px}
.swim-title{font-family:var(--mono);font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--ink-3)}
.swim-read{font-family:var(--mono);font-size:20px;font-weight:600}
.swim-meter{position:relative;height:16px;border-radius:10px;overflow:hidden;border:1px solid var(--line);background:linear-gradient(90deg,#C17A63 0%,#CBA157 34%,#8FAA8A 66%,var(--good) 100%)}
.swim-needle{position:absolute;top:-4px;width:3px;height:24px;background:#fff;border-radius:2px;box-shadow:0 0 8px rgba(0,0,0,.35);transform:translateX(-50%)}
.swim-scale{display:flex;justify-content:space-between;font-family:var(--mono);font-size:10.5px;color:var(--ink-3);margin-top:6px}

/* LSI */
.lsi-card{padding:18px}
.lsi-top{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:14px;gap:16px;flex-wrap:wrap}
.lsi-val{font-family:var(--mono);font-size:34px;font-weight:600;line-height:1}
.lsi-lab{font-family:var(--mono);font-size:11px;color:var(--ink-3);letter-spacing:.12em;margin-top:4px}
.lsi-state{font-family:var(--mono);font-size:12px;letter-spacing:.14em;text-transform:uppercase;padding:5px 10px;border-radius:20px;border:1px solid;white-space:nowrap}
.lsi-meter{position:relative;height:16px;border-radius:10px;overflow:hidden;background:linear-gradient(90deg,var(--low) 0%,var(--low) 22%,var(--good-dim) 40%,var(--good) 50%,var(--good-dim) 60%,var(--high) 78%,var(--high) 100%);border:1px solid var(--line)}
.lsi-band{position:absolute;top:0;bottom:0;background:rgba(43,33,26,.10);border-left:1px dashed rgba(43,33,26,.35);border-right:1px dashed rgba(43,33,26,.35)}
.lsi-needle{position:absolute;top:-4px;width:3px;height:24px;background:#fff;border-radius:2px;box-shadow:0 0 8px rgba(0,0,0,.35);transform:translateX(-50%)}
.lsi-scale{display:flex;justify-content:space-between;font-family:var(--mono);font-size:10.5px;color:var(--ink-3);margin-top:6px}
.lsi-note{margin-top:12px;font-size:13px;color:var(--ink-2)}
.lsi-est{margin-top:8px;font-family:var(--mono);font-size:11px;color:var(--warn)}

/* gauges */
.gauges{display:grid;grid-template-columns:1fr 1fr;gap:12px;padding:16px}
@media (max-width:560px){.gauges{grid-template-columns:1fr}}
.gauge{background:var(--bg-2);border:1px solid var(--line-soft);border-radius:11px;padding:13px 14px}
.gauge-top{display:flex;justify-content:space-between;align-items:baseline;gap:8px;margin-bottom:2px}
.gauge-name{font-family:var(--mono);font-size:11px;letter-spacing:.08em;text-transform:uppercase;color:var(--ink-2)}
.pill{font-family:var(--mono);font-size:10px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;padding:3px 7px;border-radius:12px;border:1px solid}
.gauge-read{font-family:var(--mono);font-size:26px;font-weight:600;line-height:1.1}
.gauge-read span{font-size:12px;color:var(--ink-3);font-weight:400;margin-left:3px}
.gauge-ideal{font-family:var(--mono);font-size:11px;color:var(--ink-3);margin-top:3px}
.gauge-ideal b{color:var(--ink-2);font-weight:500}
.track{position:relative;height:10px;background:var(--surface-2);border:1px solid var(--line-soft);border-radius:6px;margin:11px 0 4px;overflow:hidden}
.ideal{position:absolute;top:0;bottom:0;background:rgba(79,122,91,.14);border-left:1px solid rgba(79,122,91,.5);border-right:1px solid rgba(79,122,91,.5)}
.marker{position:absolute;top:-3px;width:3px;height:16px;border-radius:2px;transform:translateX(-50%);box-shadow:0 0 6px rgba(0,0,0,.3)}
.scale{display:flex;justify-content:space-between;font-family:var(--mono);font-size:9.5px;color:var(--ink-3)}
.gauge-fix{font-family:var(--mono);font-size:11px;margin-top:7px;min-height:1em;font-weight:500}
.tempchip{background:var(--bg-2);border:1px solid var(--line-soft);border-radius:11px;padding:13px 14px;display:flex;flex-direction:column;justify-content:center}
.tempchip .gauge-read{font-size:24px}

/* fix list */
.dose-list{padding:8px 18px 18px}
.dose{display:flex;gap:14px;padding:15px 0;border-bottom:1px solid var(--line-soft)}
.dose:last-child{border-bottom:0}
.dose .num{flex:none;width:26px;height:26px;border-radius:8px;background:var(--surface-2);border:1px solid var(--line);display:grid;place-items:center;font-family:var(--mono);font-size:12px;color:var(--accent);font-weight:600}
.dose .body{flex:1;min-width:0}
.dose .title{font-weight:600;font-size:15px;margin-bottom:2px}
.dose .title small{font-family:var(--mono);font-weight:400;color:var(--ink-3);font-size:12px;margin-left:6px}
.dose .amt{font-family:var(--mono);font-size:20px;font-weight:600;color:var(--accent);letter-spacing:-.01em}
.dose .amt small{font-size:12px;color:var(--ink-3);font-weight:400;letter-spacing:0}
.dose .sub{font-size:13px;color:var(--ink-2);margin-top:4px}
.allgood{padding:26px 18px;text-align:center;color:var(--ink-2)}
.allgood .big{font-family:var(--mono);font-size:22px;color:var(--good);letter-spacing:.02em;margin-bottom:6px}
.mode-note{font-family:var(--mono);font-size:11.5px;color:var(--ink-3);padding:12px 18px 0}

/* analytics */
.analytics{padding:8px 18px 18px}
.insight{display:flex;gap:13px;padding:14px 0;border-bottom:1px solid var(--line-soft)}
.insight:last-child{border-bottom:0}
.insight .sev{flex:none;width:8px;height:8px;border-radius:50%;margin-top:6px}
.insight .c{flex:1;min-width:0}
.insight .h{font-weight:600;font-size:15px;margin-bottom:3px}
.insight .b{font-size:13.5px;color:var(--ink-2);line-height:1.55}

/* history / trends */
.hist-controls{display:flex;flex-direction:column;gap:12px}
.hist-btns{display:flex;flex-wrap:wrap;gap:8px}
.btn{font-family:var(--mono);font-size:12px;letter-spacing:.04em;background:var(--surface-2);border:1px solid var(--line);color:var(--ink);padding:9px 14px;border-radius:8px;cursor:pointer;transition:.15s;display:inline-flex;align-items:center;gap:6px}
.btn:hover{border-color:var(--accent-dim);color:var(--accent)}
.btn.ghost{background:transparent;color:var(--ink-2)}
.btn.primary{background:rgba(193,78,11,.12);border-color:rgba(193,78,11,.4);color:var(--accent)}
.btn.primary:hover{background:rgba(193,78,11,.18)}
.file-btn input{display:none}
.hist-note{font-size:11.5px;color:var(--ink-3);font-family:var(--mono);line-height:1.6}
.hist-empty{padding:22px 4px;color:var(--ink-3);font-size:13px;font-family:var(--mono);text-align:center;border:1px dashed var(--line);border-radius:10px;margin-top:14px}
.chart-empty2{color:var(--ink-3);font-size:12.5px;font-family:var(--mono);padding:20px 4px;text-align:center;border:1px dashed var(--line);border-radius:10px}
.hist-table-wrap{overflow-x:auto;margin-top:10px;border:1px solid var(--line-soft);border-radius:10px}
table.hist-table{width:100%;border-collapse:collapse;font-family:var(--mono);font-size:12px}
table.hist-table th{text-align:left;color:var(--ink-3);font-weight:500;padding:8px 10px;border-bottom:1px solid var(--line-soft);white-space:nowrap;text-transform:uppercase;letter-spacing:.06em;font-size:10.5px}
table.hist-table td{padding:7px 10px;border-bottom:1px solid var(--line-soft);color:var(--ink-2);white-space:nowrap}
table.hist-table tr:last-child td{border-bottom:0}
table.hist-table td.del{cursor:pointer;color:var(--ink-3);text-align:center}
table.hist-table td.del:hover{color:var(--high)}

/* info cards */
.cards{display:grid;grid-template-columns:1fr 1fr;gap:22px;margin-top:22px}
@media (max-width:940px){.cards{grid-template-columns:1fr}}
.kv{display:flex;justify-content:space-between;gap:12px;padding:10px 0;border-bottom:1px solid var(--line-soft);font-size:13.5px}
.kv:last-child{border-bottom:0}
.kv .k{color:var(--ink-2)}
.kv .v{font-family:var(--mono);color:var(--ink);text-align:right}
.kv .v.flag{color:var(--high)}
.kv .v.good{color:var(--good)}
.relations{font-size:13.5px;color:var(--ink-2);line-height:1.65}
.relations .r{padding:9px 0;border-bottom:1px solid var(--line-soft);display:flex;gap:10px}
.relations .r:last-child{border-bottom:0}
.relations .r .ic{flex:none;font-family:var(--mono);color:var(--accent-dim);font-size:12px;padding-top:2px}
.relations b{color:var(--ink);font-weight:600}
.safety li{margin-bottom:8px;font-size:13.5px;color:var(--ink-2)}
.safety b{color:var(--warn)}
.footer-note{margin-top:26px;font-size:12px;color:var(--ink-3);font-family:var(--mono);line-height:1.7;border-top:1px solid var(--line-soft);padding-top:16px}

.hide{display:none !important}
:focus-visible{outline:2px solid var(--accent);outline-offset:2px}
</style>
</head>
<body>
<div class="wrap">

  <header>
    <div class="brandline">
      <span class="wordmark">Water<b>line</b></span>
      <span class="tag">Pool Chemistry Console</span>
    </div>
    <p class="subhead">Enter your daily probe readings: pH, chlorine, ORP, and temp, for a quick read on what's going on and how to fix it. Switch to Full test when you've run the whole panel, and log readings over time to see how things are trending.</p>
  </header>

  <div class="grid">

    <!-- ============ INPUTS ============ -->
    <div class="panel inputs">
      <div class="panel-head"><span class="idx">IN</span><h2>Readings &amp; Setup</h2></div>
      <div class="panel-body">

        <!-- VOLUME -->
        <div class="field">
          <label class="lab">Pool volume</label>
          <div class="seg" id="volmode">
            <button data-vm="enter" class="on">Enter gallons</button>
            <button data-vm="calc">Calculate</button>
          </div>
        </div>
        <div id="vol-enter" class="field">
          <input type="number" id="vol_gal" value="20000" min="100" step="100">
          <div class="hint" id="vol_liters">approx 75,700 L</div>
        </div>
        <div id="vol-calc" class="hide">
          <div class="field">
            <label class="lab">Shape</label>
            <select id="shape"><option value="rect">Rectangle</option><option value="round">Round</option><option value="oval">Oval</option></select>
          </div>
          <div class="row2">
            <div class="field"><label class="lab" id="dimA_l">Length (ft)</label><input type="number" id="dimA" value="32" step="1"></div>
            <div class="field" id="dimB_wrap"><label class="lab" id="dimB_l">Width (ft)</label><input type="number" id="dimB" value="16" step="1"></div>
          </div>
          <div class="row2">
            <div class="field"><label class="lab">Shallow (ft)</label><input type="number" id="depthS" value="3.5" step="0.5"></div>
            <div class="field"><label class="lab">Deep (ft)</label><input type="number" id="depthD" value="8" step="0.5"></div>
          </div>
          <div class="volout"><small>Computed volume</small><b id="vol_calc_out">gal</b></div>
        </div>

        <div class="divider"></div>
        <div class="mini-lab"><span class="dot"></span>Setup</div>
        <div class="field">
          <label class="lab">Location</label>
          <div class="seg" id="loc"><button data-loc="outdoor" class="on">Outdoor</button><button data-loc="indoor">Indoor</button></div>
        </div>
        <div class="field">
          <label class="lab">Surface</label>
          <select id="surface"><option value="plaster">Plaster / Gunite / Concrete</option><option value="vinyl">Vinyl liner</option><option value="fiberglass">Fiberglass</option></select>
        </div>
        <div class="field">
          <label class="lab">Primary sanitizer</label>
          <select id="sanitizer">
            <option value="liquid">Sodium hypochlorite</option>
            <option value="salt">Salt / SWG generator</option>
            <option value="trichlor">Trichlor tablets</option>
            <option value="calhypo">Cal-hypo (granular)</option>
          </select>
        </div>

        <div class="divider"></div>
        <div class="mini-lab"><span class="dot"></span>Test type</div>
        <div class="field">
          <div class="seg" id="readmode">
            <button data-rm="daily" class="on">Daily</button>
            <button data-rm="full">Full test</button>
          </div>
          <div class="hint">Daily = probe readings. Full = complete panel.</div>
        </div>

        <!-- DAILY READINGS -->
        <div class="row2">
          <div class="field"><label class="lab">pH</label><input type="number" id="pH" value="6.9" step="0.1"></div>
          <div class="field"><label class="lab">Free Cl (ppm)</label><input type="number" id="fc" value="0.8" step="0.1"></div>
        </div>
        <div class="row2">
          <div class="field"><label class="lab">ORP (mV)</label><input type="number" id="orp" value="720" step="5"><div class="hint">Sanitizer strength</div></div>
          <div class="field"><label class="lab">Water F</label><input type="number" id="temp" value="82" step="1"></div>
        </div>

        <!-- ADVANCED READINGS -->
        <div id="adv-readings" class="hide">
          <div class="divider"></div>
          <div class="mini-lab"><span class="dot"></span>Full panel</div>
          <div class="row2">
            <div class="field"><label class="lab">Alkalinity (ppm)</label><input type="number" id="ta" value="90" step="5"></div>
            <div class="field"><label class="lab">Calcium (ppm)</label><input type="number" id="ch" value="250" step="10"></div>
          </div>
          <div class="row2">
            <div class="field"><label class="lab">Cyanuric (ppm)</label><input type="number" id="cya" value="50" step="5"></div>
            <div class="field"><label class="lab">Combined Cl (ppm)</label><input type="number" id="cc" value="0" step="0.1"><div class="hint">Total minus Free</div></div>
          </div>
          <div class="row2">
            <div class="field" id="salt-field"><label class="lab">Salt (ppm)</label><input type="number" id="salt" value="3000" step="100"></div>
            <div class="field"><label class="lab">TDS (ppm)</label><input type="number" id="tds" value="1000" step="100"></div>
          </div>
        </div>

      </div>
    </div>

    <!-- ============ DASHBOARD ============ -->
    <div>

      <!-- 01 WATER STATUS -->
      <div class="panel" style="margin-bottom:22px">
        <div class="panel-head"><span class="idx">01</span><h2>Water Status</h2></div>
        <div class="verdict" id="verdict"></div>
        <div class="lsi-card">
          <div class="lsi-top">
            <div><div class="lsi-val" id="lsi_val">-</div><div class="lsi-lab">SATURATION INDEX / SCALE-CORROSION BALANCE</div></div>
            <div class="lsi-state" id="lsi_state">-</div>
          </div>
          <div class="lsi-meter"><div class="lsi-band" id="lsi_band"></div><div class="lsi-needle" id="lsi_needle"></div></div>
          <div class="lsi-scale"><span>-1.0 corrosive</span><span>-0.3</span><span>0.0 balanced</span><span>+0.3</span><span>+1.0 scaling</span></div>
          <div class="lsi-note" id="lsi_note"></div>
          <div class="lsi-est hide" id="lsi_est">Estimated from your last full-panel values. Run a Full test to refresh balance.</div>
        </div>
      </div>

      <!-- 02 PARAMETER STATUS -->
      <div class="panel" style="margin-bottom:22px">
        <div class="panel-head"><span class="idx">02</span><h2>Parameter Status &amp; Ideal Ranges</h2></div>
        <div class="gauges" id="gauges"></div>
      </div>

      <!-- 03 FIXES -->
      <div class="panel" style="margin-bottom:22px">
        <div class="panel-head"><span class="idx">03</span><h2>Get Back in Range</h2><span class="note" id="fix-order"></span></div>
        <div id="mode-note" class="mode-note hide"></div>
        <div id="dose-list" class="dose-list"></div>
      </div>

      <!-- 04 ANALYTICS -->
      <div class="panel" style="margin-bottom:22px">
        <div class="panel-head"><span class="idx">04</span><h2>Advanced Analytics</h2><span class="note">likely root causes</span></div>
        <div class="analytics" id="analytics"></div>
      </div>

      <!-- 05 TRENDS & HISTORY -->
      <div class="panel">
        <div class="panel-head"><span class="idx">05</span><h2>Trends &amp; History</h2><span class="note">import past tests to see how things are moving</span></div>
        <div class="panel-body">
          <div class="hist-controls">
            <div class="field" style="max-width:220px">
              <label class="lab">Date to log</label>
              <input type="date" id="hist_date">
            </div>
            <div class="hist-btns">
              <button class="btn primary" id="hist_log">Log current reading</button>
              <label class="btn file-btn">Import CSV<input type="file" id="hist_import" accept=".csv"></label>
              <button class="btn" id="hist_export">Export CSV</button>
              <button class="btn ghost" id="hist_sample">Load sample data</button>
              <button class="btn ghost" id="hist_clear">Clear history</button>
            </div>
            <div class="hist-note">Logging saves whatever is currently in the Readings panel, tagged with this date. Logging again on the same date updates that entry instead of duplicating it. CSV columns: date, pH, fc, orp, ta, ch, cya, salt, tds, cc, temp. Any subset works, and this is also the format Export CSV produces, so exporting and re-importing later is how your log carries over between sessions.</div>
          </div>

          <div id="hist_empty" class="hist-empty">No history yet. Log today's reading, import a CSV of past tests, or load sample data to see how this section works.</div>

          <div id="hist_content" class="hide">
